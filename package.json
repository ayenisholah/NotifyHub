{
  "name": "notifyhub",
  "version": "0.1.0",
  "description": "Production-shaped multi-channel notification service with durable delivery workers, an embeddable inbox, and a public observability dashboard.",
  "private": true,
  "license": "MIT",
  "author": {
    "name": "Shola Ayeni",
    "url": "https://github.com/ayenisholah"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/ayenisholah/NotifyHub.git"
  },
  "bugs": {
    "url": "https://github.com/ayenisholah/NotifyHub/issues"
  },
  "homepage": "https://notifyhub.sholaayeni.xyz/",
  "keywords": [
    "notifications",
    "multi-channel",
    "email",
    "sms",
    "in-app",
    "delivery-workers",
    "observability",
    "typescript"
  ],
  "type": "module",
  "packageManager": "npm@10.9.2",
  "engines": {
    "node": ">=22"
  },
  "workspaces": [
    "packages/*"
  ],
  "overrides": {
    "@hono/node-server": "1.19.13"
  },
  "dependencies": {
    "prisma": "^7.8.0"
  },
  "scripts": {
    "assets:generate": "node scripts/generate-seo-assets.mjs",
    "build": "tsc -b && npm run build -w @notifyhub/widget && npm run build -w @notifyhub/demo-host && npm run build -w @notifyhub/dashboard",
    "clean": "tsc -b --clean && npm run clean -w @notifyhub/dashboard",
    "format": "prettier --write .",
    "format:check": "prettier --check .",
    "lint": "eslint .",
    "prisma:generate": "prisma generate",
    "prisma:migrate:deploy": "prisma migrate deploy",
    "postinstall": "npm run prisma:generate",
    "test": "vitest run && vitest run --config vitest.widget.config.ts && npm test -w @notifyhub/demo-host && npm test -w @notifyhub/dashboard",
    "test:integration": "vitest run --config vitest.integration.config.ts",
    "test:e2e": "playwright test",
    "test:kill": "npm run build && vitest run --config vitest.reliability.config.ts",
    "typecheck": "tsc -b --pretty false && npm run typecheck -w @notifyhub/widget && npm run build -w @notifyhub/widget && npm run typecheck -w @notifyhub/demo-host && npm run typecheck -w @notifyhub/dashboard",
    "verify": "npm run clean && npm run format:check && npm run lint && npm run typecheck && npm run build && npm run smoke -w @notifyhub/demo-host && npm run smoke -w @notifyhub/dashboard && npm test",
    "start:api": "npm run start:api -w @notifyhub/runtime",
    "measure": "npm run measure -w @notifyhub/runtime",
    "retention": "npm run retention -w @notifyhub/runtime",
    "start:router": "npm run start:router -w @notifyhub/runtime",
    "start:digest": "npm run start:digest -w @notifyhub/runtime",
    "start:email": "npm run start:email -w @notifyhub/runtime",
    "start:sms": "npm run start:sms -w @notifyhub/runtime",
    "start:inapp": "npm run start:inapp -w @notifyhub/runtime"
  },
  "devDependencies": {
    "@eslint/js": "^9.30.1",
    "@playwright/test": "^1.61.1",
    "@testcontainers/postgresql": "^12.0.4",
    "@types/express": "^5.0.6",
    "@types/node": "^22.15.34",
    "@types/nodemailer": "^8.0.1",
    "@types/pg": "^8.20.0",
    "@types/supertest": "^7.2.0",
    "@types/ws": "^8.18.1",
    "eslint": "^9.30.1",
    "eslint-config-prettier": "^10.1.5",
    "globals": "^16.2.0",
    "prettier": "^3.6.2",
    "supertest": "^7.2.2",
    "testcontainers": "^12.0.4",
    "typescript": "^5.8.3",
    "typescript-eslint": "^8.35.1",
    "vitest": "^3.2.4"
  }
}
