{
  "name": "notifyhub",
  "version": "0.1.0",
  "private": true,
  "license": "MIT",
  "type": "module",
  "engines": {
    "node": ">=22"
  },
  "workspaces": [
    "packages/*"
  ],
  "overrides": {
    "@hono/node-server": "1.19.13"
  },
  "scripts": {
    "build": "tsc -b && npm run build -w @notifyhub/widget",
    "clean": "tsc -b --clean",
    "format": "prettier --write .",
    "format:check": "prettier --check .",
    "lint": "eslint .",
    "prisma:generate": "prisma generate",
    "prisma:migrate:deploy": "prisma migrate deploy",
    "postinstall": "npm run prisma:generate",
    "test": "vitest run && vitest run --config vitest.widget.config.ts",
    "test:integration": "vitest run --config vitest.integration.config.ts",
    "test:kill": "npm run build && vitest run --config vitest.reliability.config.ts",
    "typecheck": "tsc -b --pretty false && npm run typecheck -w @notifyhub/widget",
    "verify": "npm run format:check && npm run lint && npm run typecheck && npm run build && npm test"
  },
  "devDependencies": {
    "@eslint/js": "^9.30.1",
    "@testcontainers/postgresql": "^12.0.4",
    "@types/express": "^5.0.6",
    "@types/node": "^22.15.34",
    "@types/nodemailer": "^8.0.1",
    "@types/pg": "^8.20.0",
    "@types/supertest": "^7.2.0",
    "@types/ws": "^8.18.1",
    "eslint": "^9.30.1",
    "eslint-config-prettier": "^10.1.5",
    "globals": "^16.2.0",
    "prettier": "^3.6.2",
    "prisma": "^7.8.0",
    "supertest": "^7.2.2",
    "testcontainers": "^12.0.4",
    "typescript": "^5.8.3",
    "typescript-eslint": "^8.35.1",
    "vitest": "^3.2.4"
  }
}
