# Docker Compose infrastructure. POSTGRES_PASSWORD must be URI-safe because Compose
# also uses it to construct DATABASE_URL for application containers.
POSTGRES_DB=notifyhub
POSTGRES_USER=notifyhub
POSTGRES_PASSWORD=replace-with-database-password
DATABASE_URL=postgresql://notifyhub:replace-with-database-password@postgres:4132/notifyhub
REDIS_URL=redis://redis:4137

# Replace these non-production placeholders with unique secrets (minimum 32 characters).
API_KEY=replace-with-local-api-key-32-chars
OPERATOR_KEY=replace-with-local-operator-key-32
TOKEN_SECRET=replace-with-local-token-secret-32-

# Email provider (mailpit, resend, or sendgrid). Only the selected provider's settings are required.
EMAIL_PROVIDER=mailpit
EMAIL_FROM=NotifyHub <notifyhub@example.test>
MAILPIT_HOST=mailpit
MAILPIT_PORT=4126
RESEND_API_KEY=replace-with-resend-api-key
SENDGRID_API_KEY=replace-with-sendgrid-api-key

# Deterministic local SMS provider; set the rate between 0 and 1 for failure demos.
SMS_PROVIDER=mock
MOCK_SMS_FAILURE_RATE=0

# Optional application settings
NODE_ENV=development
PORT=4101
LOG_LEVEL=info
WS_ALLOWED_ORIGINS=http://localhost:4100,http://127.0.0.1:4100

# Acme Projects demo host and public dashboard scope (API_KEY remains server-side and is never bundled).
DEMO_PORT=4100
DEMO_HOST=0.0.0.0
DEMO_API_BASE_URL=http://api:4101
DEMO_USER_ID=notifyhub-demo

# Loopback-only host ports. Host Nginx owns public ports 80 and 443.
NOTIFYHUB_DEMO_PORT=4100
NOTIFYHUB_API_PORT=4101
NOTIFYHUB_MAILPIT_UI_PORT=4125
