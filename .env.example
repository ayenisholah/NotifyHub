# Local infrastructure (safe development defaults)
DATABASE_URL=postgresql://notifyhub:notifyhub@localhost:5432/notifyhub
REDIS_URL=redis://localhost:6379

# Replace these non-production placeholders with unique secrets (minimum 32 characters).
API_KEY=replace-with-local-api-key-32-chars
OPERATOR_KEY=replace-with-local-operator-key-32
TOKEN_SECRET=replace-with-local-token-secret-32-

# Email provider (mailpit, resend, or sendgrid). Only the selected provider's settings are required.
EMAIL_PROVIDER=mailpit
EMAIL_FROM=NotifyHub <notifyhub@example.test>
MAILPIT_HOST=localhost
MAILPIT_PORT=1025
RESEND_API_KEY=replace-with-resend-api-key
SENDGRID_API_KEY=replace-with-sendgrid-api-key

# Deterministic local SMS provider; set the rate between 0 and 1 for failure demos.
SMS_PROVIDER=mock
MOCK_SMS_FAILURE_RATE=0

# Optional application settings
NODE_ENV=development
PORT=4000
LOG_LEVEL=info

# Acme Projects demo host (API_KEY remains server-side and is never bundled).
DEMO_PORT=3000
DEMO_API_BASE_URL=http://127.0.0.1:4000
DEMO_USER_ID=replace-with-synthetic-demo-user-id
